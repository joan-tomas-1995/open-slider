{
  "name": "@open-slider/angular",
  "version": "0.1.0",
  "description": "Angular adapter for Open Slider",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@angular/core": ">=17.0.0",
    "rxjs": ">=7.0.0"
  },
  "dependencies": {
    "@open-slider/core": "0.1.0"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --external @angular/core --external rxjs",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  }
}
