{
  "name": "@open-slider/styles",
  "version": "0.2.0",
  "description": "Default styles and CSS variables for Open Slider",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./css": "./src/index.css"
  },
  "files": [
    "dist",
    "src/index.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "typecheck": "tsc -p ../../tsconfig.json --noEmit"
  }
}
